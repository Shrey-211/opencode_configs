# OpenCode Autonomy System - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# TELEGRAM BOT CONFIGURATION
# ============================================
# Get your token from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Optional: Restrict bot access to specific chat IDs (comma-separated)
# Leave empty to allow all chats
ALLOWED_CHAT_IDS=

# ============================================
# AI API KEYS (Optional)
# ============================================
# Google Gemini API Key (for advanced features)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (for advanced features)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# REDIS CONFIGURATION
# ============================================
# Redis server connection settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# SYSTEM MONITORING THRESHOLDS
# ============================================
# Alert thresholds (percentage)
CPU_THRESHOLD=90
RAM_THRESHOLD=85
DISK_THRESHOLD=90

# ============================================
# SECURITY SETTINGS
# ============================================
# Require confirmation for dangerous commands
REQUIRE_CONFIRMATION=true

# Commands that require user confirmation
DANGEROUS_COMMANDS=shutdown,restart,kill,rm,format,mkfs

# ============================================
# DIRECTORY PATHS
# ============================================
# Workspace directory for file operations
WORKSPACE_PATH=D:/workspace/open_code

# Screenshot directory
SCREENSHOT_DIR=D:/workspace/open_code/screenshots

# ============================================
# OPTIONAL SETTINGS
# ============================================
# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Bot polling interval (seconds)
POLLING_INTERVAL=1
